{
  "name": "@stemcell/tokens",
  "version": "0.0.0-alpha.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/web/base.js",
      "types": "./dist/web/base.d.ts"
    },
    "./standard-light": {
      "import": "./dist/web/standard-light.js",
      "types": "./dist/web/standard-light.d.ts"
    },
    "./standard-dark": {
      "import": "./dist/web/standard-dark.js",
      "types": "./dist/web/standard-dark.d.ts"
    },
    "./types": {
      "import": "./dist/web/types.js",
      "types": "./dist/web/types.d.ts"
    },
    "./density-compact": {
      "import": "./dist/web/density-compact.js",
      "types": "./dist/web/density-compact.d.ts"
    },
    "./base.css": "./dist/web/base.css",
    "./standard-light.css": "./dist/web/standard-light.css",
    "./standard-dark.css": "./dist/web/standard-dark.css",
    "./standard.css": "./dist/web/standard.css",
    "./density-compact.css": "./dist/web/density-compact.css",

    "./dtcg/base": "./src/base.tokens.json",
    "./dtcg/elevation": "./src/elevation.tokens.json",
    "./dtcg/standard-light": "./src/theme/standard-light.json",
    "./dtcg/standard-dark": "./src/theme/standard-dark.json",
    "./dtcg/compact": "./src/density/compact.json"
  },
  "files": [
    "dist/web/",
    "src/**/*.json"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun run style-dictionary.config.ts && bunx tsc --project tsconfig.build.json",
    "check": "bunx tsc --noEmit && bun run check:palette",
    "check:palette": "bun src/checks/run.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "style-dictionary": "^5.4.0",
    "typescript": "^5"
  }
}
