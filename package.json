{
  "name": "stemcell-tokens",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/web/base.js",
      "types": "./dist/web/base.d.ts"
    },
    "./standard-light": {
      "import": "./dist/web/standard-light.js",
      "types": "./dist/web/standard-light.d.ts"
    },
    "./base.css": "./dist/web/base.css",
    "./standard-light.css": "./dist/web/standard-light.css"
  },
  "files": [
    "dist/web/"
  ],
  "scripts": {
    "build": "bun run style-dictionary.config.ts && bunx tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "style-dictionary": "^5.4.0",
    "typescript": "^5"
  }
}
