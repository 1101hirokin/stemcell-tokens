    "font-weight": {
        "regular":  { "$type": "fontWeight", "$value": 400, "$description": "Regular." },
        "medium":   { "$type": "fontWeight", "$value": 500, "$description": "Medium." },
        "semibold": { "$type": "fontWeight", "$value": 600, "$description": "Semibold." },
        "bold":     { "$type": "fontWeight", "$value": 700, "$description": "Bold." }
    },

    "font-size": {
        "0": { "$type": "fontSize", "$value": "42px",   "$description": "Harmonic 84/(n+2), n=0 (max). fontSize type -> web rem / native sp / iOS Dynamic Type." },
        "1": { "$type": "fontSize", "$value": "28px",   "$description": "n=1." },
        "2": { "$type": "fontSize", "$value": "21px",   "$description": "n=2." },
        "3": { "$type": "fontSize", "$value": "16.8px", "$description": "n=3." },
        "4": { "$type": "fontSize", "$value": "14px",   "$description": "n=4 (body base)." },
        "5": { "$type": "fontSize", "$value": "12px",   "$description": "n=5 (regularized 11.62 -> 84/7 = 12)." },
        "6": { "$type": "fontSize", "$value": "10.5px", "$description": "n=6." }
    },

    "line-height": { "$type": "number", "$value": 1.334, "$description": "Line-height ratio, fixed across all roles." },

    "letter-spacing": {
        "tight":  { "$type": "dimension", "$value": "-0.01em", "$description": "Large headings." },
        "normal": { "$type": "dimension", "$value": "0em",     "$description": "Body." },
        "wide":   { "$type": "dimension", "$value": "0.02em",  "$description": "Labels." },
        "wider":  { "$type": "dimension", "$value": "0.08em",  "$description": "Overline / caps." }
    },

    "elevation": {
        "flat":         { "level": { "$value": 0, "$type": "number", "$description": "Depth of the ground plane. The level is the normative datum — the ordering and the assignment of components to levels hold on every platform, while how a level is drawn (shadow / tonal / glass) is expressive and theme-owned (Constitution Art.2). The surface and shadow facets live in the theme files because they vary by theme; the level does not, so it lives here. Platforms that render from the level itself rather than from CSS geometry (Compose shadowElevation, SwiftUI) consume this token." } },
        "surface":      { "level": { "$value": 1, "$type": "number", "$description": "Card / panel / alert / table." } },
        "navigation":   { "level": { "$value": 2, "$type": "number", "$description": "App bar / sidebar / sticky header / tab bar." } },
        "popover":      { "level": { "$value": 3, "$type": "number", "$description": "Menu / dropdown / select / combobox / popover. Tooltip draws at this depth but stacks at --layer-tooltip." } },
        "modal":        { "level": { "$value": 4, "$type": "number", "$description": "Modal / dialog / drawer / sheet." } },
        "notification": { "level": { "$value": 5, "$type": "number", "$description": "Toast / snackbar." } }
    },

    "spacing": {
        "0":  { "$type": "dimension", "$value": "0px",  "$description": "4*0 px." },
        "1":  { "$type": "dimension", "$value": "4px",  "$description": "4*1 px." },
        "2":  { "$type": "dimension", "$value": "8px",  "$description": "4*2 px." },
        "3":  { "$type": "dimension", "$value": "12px", "$description": "4*3 px." },
        "4":  { "$type": "dimension", "$value": "16px", "$description": "4*4 px." },
        "5":  { "$type": "dimension", "$value": "20px", "$description": "4*5 px." },
        "6":  { "$type": "dimension", "$value": "24px", "$description": "4*6 px." },
        "7":  { "$type": "dimension", "$value": "28px", "$description": "4*7 px." },
        "8":  { "$type": "dimension", "$value": "32px", "$description": "4*8 px." },
        "9":  { "$type": "dimension", "$value": "36px", "$description": "4*9 px." },
        "10": { "$type": "dimension", "$value": "40px", "$description": "4*10 px." },
        "11": { "$type": "dimension", "$value": "44px", "$description": "4*11 px." },
        "12": { "$type": "dimension", "$value": "48px", "$description": "4*12 px." },
        "13": { "$type": "dimension", "$value": "52px", "$description": "4*13 px." },
        "14": { "$type": "dimension", "$value": "56px", "$description": "4*14 px." },
        "15": { "$type": "dimension", "$value": "60px", "$description": "4*15 px." },
        "16": { "$type": "dimension", "$value": "64px", "$description": "4*16 px." },
        "17": { "$type": "dimension", "$value": "68px", "$description": "4*17 px." },
        "18": { "$type": "dimension", "$value": "72px", "$description": "4*18 px." },
        "19": { "$type": "dimension", "$value": "76px", "$description": "4*19 px." },
        "20": { "$type": "dimension", "$value": "80px", "$description": "4*20 px." },
        "21": { "$type": "dimension", "$value": "84px", "$description": "4*21 px." },
        "22": { "$type": "dimension", "$value": "88px", "$description": "4*22 px." },
        "23": { "$type": "dimension", "$value": "92px", "$description": "4*23 px." },
        "24": { "$type": "dimension", "$value": "96px", "$description": "4*24 px." },

        "inset":  { "sm": { "$type": "dimension", "$value": "{spacing.2}", "$description": "8px." },  "md": { "$type": "dimension", "$value": "{spacing.4}", "$description": "16px." }, "lg": { "$type": "dimension", "$value": "{spacing.6}", "$description": "24px." } },
        "stack":  { "sm": { "$type": "dimension", "$value": "{spacing.2}", "$description": "8px." },  "md": { "$type": "dimension", "$value": "{spacing.4}", "$description": "16px." }, "lg": { "$type": "dimension", "$value": "{spacing.6}", "$description": "24px." } },
        "inline": { "sm": { "$type": "dimension", "$value": "{spacing.1}", "$description": "4px." },  "md": { "$type": "dimension", "$value": "{spacing.2}", "$description": "8px." },  "lg": { "$type": "dimension", "$value": "{spacing.3}", "$description": "12px." } },
        "gap":    { "sm": { "$type": "dimension", "$value": "{spacing.2}", "$description": "8px." },  "md": { "$type": "dimension", "$value": "{spacing.4}", "$description": "16px." }, "lg": { "$type": "dimension", "$value": "{spacing.6}", "$description": "24px." } }
    },

    "shape": {
        "circular":  { "$type": "borderRadius", "$value": "999999px", "$description": "Full pill." },
        "rounded-s": { "$type": "borderRadius", "$value": "2px",      "$description": "Subtle rounding — tags, badges." },
        "rounded-m": { "$type": "borderRadius", "$value": "6px",      "$description": "Standard rounding — buttons, inputs, cards." },
        "rounded-l": { "$type": "borderRadius", "$value": "10px",     "$description": "Large rounding — dialogs, sheets." },
        "angular":   { "$type": "borderRadius", "$value": "0px",      "$description": "No rounding." },
        "smoothing": { "$type": "number", "$value": 0.6, "$description": "Continuous corner smoothing (superellipse). 0=plain arc; ~0.6 approximates iOS .continuous / Figma 60% / Compose 0.6f. Falls back to a plain arc where unsupported (Constitution Art.7)." },

        "semantic": {
            "control":   { "$type": "borderRadius", "$value": "{shape.rounded-m}", "$description": "Button, input, select, textarea." },
            "selection": { "$type": "borderRadius", "$value": "{shape.rounded-s}", "$description": "Checkbox." },
            "card":      { "$type": "borderRadius", "$value": "{shape.rounded-m}", "$description": "Card, panel, alert, surface, image." },
            "dialog":    { "$type": "borderRadius", "$value": "{shape.rounded-l}", "$description": "Modal, dialog, bottom sheet, drawer." },
            "popover":   { "$type": "borderRadius", "$value": "{shape.rounded-m}", "$description": "Tooltip, dropdown menu, combobox popup." },
            "pill":      { "$type": "borderRadius", "$value": "{shape.circular}",  "$description": "Badge, progress bar, avatar, radio, switch." },
            "tag":       { "$type": "borderRadius", "$value": "{shape.rounded-s}", "$description": "Tag, chip, small badge." }
        }
    },

    "font-family": {
        "normal": {
            "$type": "fontFamily",
            "$value": "\"Segoe UI\", -apple-system, BlinkMacSystemFont, Roboto, \"Noto Sans\", \"BIZ UDゴシック\", system-ui, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\""
        },
        "code": {
            "$type": "fontFamily",
            "$value": "\"Source Code Pro\", Menlo, Monaco, \"Ubuntu Mono\", \"Fira Code\", Consolas, \"Courier New\", \"Segoe UI\", \"Helvetica Neue\", \"BIZ UDPゴシック\", sans-serif, system-ui, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\", monospace"
        }
    },

    "typography": {
        "display-lg":  { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.semibold}", "fontSize": "{font-size.0}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.tight}" } },
        "display-md":  { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.semibold}", "fontSize": "{font-size.1}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.tight}" } },
        "headline-lg": { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.bold}", "fontSize": "{font-size.1}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.tight}" } },
        "headline-md": { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.bold}", "fontSize": "{font-size.2}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.tight}" } },
        "headline-sm": { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.bold}", "fontSize": "{font-size.3}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.tight}" } },
        "title-lg":    { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.semibold}", "fontSize": "{font-size.2}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } },
        "title-md":    { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.semibold}", "fontSize": "{font-size.3}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } },
        "title-sm":    { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.semibold}", "fontSize": "{font-size.4}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } },
        "body-lg":     { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.regular}", "fontSize": "{font-size.3}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } },
        "body-md":     { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.regular}", "fontSize": "{font-size.4}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } },
        "body-sm":     { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.regular}", "fontSize": "{font-size.5}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } },
        "label-lg":    { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.medium}", "fontSize": "{font-size.4}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.wide}" } },
        "label-md":    { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.medium}", "fontSize": "{font-size.5}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.wide}" } },
        "label-sm":    { "$type": "typography", "$value": { "fontFamily": "{font-family.normal}", "fontWeight": "{font-weight.medium}", "fontSize": "{font-size.6}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.wide}" } },
        "mono-md":     { "$type": "typography", "$value": { "fontFamily": "{font-family.code}", "fontWeight": "{font-weight.regular}", "fontSize": "{font-size.4}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } },
        "mono-sm":     { "$type": "typography", "$value": { "fontFamily": "{font-family.code}", "fontWeight": "{font-weight.regular}", "fontSize": "{font-size.5}", "lineHeight": "{line-height}", "letterSpacing": "{letter-spacing.normal}" } }
    },
    "focus-ring": {
        "width": { "$type": "dimension", "$value": "2px", "$description": "Focus ring thickness (outline-width). WCAG 2.2 minimum." },
        "offset": { "$type": "dimension", "$value": "2px", "$description": "Focus ring offset (outline-offset). Gap between the element edge and the ring so the background shows through, improving visibility." },
        "style": { "$type": "strokeStyle", "$value": "solid", "$description": "Focus ring line style (outline-style)." }
    },
    "motion": {
        "duration": {
            "fast-01":     { "$value": "70ms",  "$type": "duration", "$description": "Carbon fast-01. Micro feedback." },
            "fast-02":     { "$value": "110ms", "$type": "duration", "$description": "Carbon fast-02. Hover/press/toggle feedback." },
            "moderate-01": { "$value": "150ms", "$type": "duration", "$description": "Carbon moderate-01. General transitions and exits." },
            "moderate-02": { "$value": "240ms", "$type": "duration", "$description": "Carbon moderate-02. Entrances and expand/collapse." },
            "slow-01":     { "$value": "400ms", "$type": "duration", "$description": "Carbon slow-01. Large surfaces." },
            "slow-02":     { "$value": "700ms", "$type": "duration", "$description": "Carbon slow-02. Loops (spinner/skeleton)." }
        },
        "easing": {
            "standard": { "$value": [0.2, 0.0, 0.38, 0.9], "$type": "cubicBezier", "$description": "ease-out. Entrances and general transitions; the spring fallback." },
            "exit":     { "$value": [0.2, 0.0, 1.0, 1.0],  "$type": "cubicBezier", "$description": "accelerate. Dismissals." },
            "linear":   { "$value": [0.0, 0.0, 1.0, 1.0],  "$type": "cubicBezier", "$description": "Linear. Loops and the none/reduced result." }
        },
        "scale": { "$value": 1, "$type": "number", "$description": "Ambient motion multiplier. Components multiply durations by this; reduced-motion sets it to 0 (Constitution Art.6)." },

        "none": {
            "duration": { "$value": "0ms", "$type": "duration", "$description": "Instant. The reduced-motion result." },
            "easing":   { "$value": "{motion.easing.linear}", "$type": "cubicBezier" }
        },
        "feedback": {
            "duration": { "$value": "{motion.duration.fast-02}", "$type": "duration", "$description": "Hover/press/toggle." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "transition": {
            "duration": { "$value": "{motion.duration.moderate-01}", "$type": "duration", "$description": "General property change." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "entrance": {
            "duration": { "$value": "{motion.duration.moderate-02}", "$type": "duration", "$description": "Element appears." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "exit": {
            "duration": { "$value": "{motion.duration.moderate-01}", "$type": "duration", "$description": "Element dismisses (faster than entrance)." },
            "easing":   { "$value": "{motion.easing.exit}", "$type": "cubicBezier" }
        },
        "expand": {
            "duration": { "$value": "{motion.duration.moderate-02}", "$type": "duration", "$description": "Accordion/collapse/disclosure height." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "loop": {
            "duration": { "$value": "{motion.duration.slow-02}", "$type": "duration", "$description": "Spinner/skeleton (infinite)." },
            "easing":   { "$value": "{motion.easing.linear}", "$type": "cubicBezier" }
        }
    },
    "layer": {
        "base":         { "$value": 0,    "$type": "number", "$description": "App ground plane: body / background / flat controls. Surface content (card, panel, alert, table) shares this z. Components must reference these tokens instead of writing raw z-index values (Constitution Art.3, structural layer)." },
        "navigation":   { "$value": 10,   "$type": "number", "$description": "Persistent chrome: app bar / sidebar / sticky header / tab bar." },
        "popover":      { "$value": 1000, "$type": "number", "$description": "Trigger-anchored transient surfaces: menu / dropdown / select / combobox / popover." },
        "scrim":        { "$value": 1300, "$type": "number", "$description": "Dimming veil behind a modal; sits below the modal it belongs to. Stacking order only — the visual value (color/opacity) belongs to elevation." },
        "modal":        { "$value": 1400, "$type": "number", "$description": "Focus-trapped surfaces: modal / dialog / drawer / sheet." },
        "notification": { "$value": 1700, "$type": "number", "$description": "Frontmost transient messages: toast / snackbar." },
        "tooltip":      { "$value": 1800, "$type": "number", "$description": "Above every other layer despite drawing at popover depth — visual depth and stacking order are separate axes." }
    },
    "breakpoint": {
        "compact":  { "$value": "0",      "$type": "breakpoint", "$description": "Handset. Page-skeleton structure only — components reflow on their own via container queries / intrinsic sizing, and consumers should not write breakpoint values (layout.md §3). Device-pixel by intent: these map 1:1 onto native size classes (Material WindowSizeClass, SwiftUI horizontalSizeClass), which do not shift with user font scaling, so they are deliberately not converted to rem (Constitution Art.2)." },
        "medium":   { "$value": "600px",  "$type": "breakpoint", "$description": "Tablet portrait and up." },
        "expanded": { "$value": "840px",  "$type": "breakpoint", "$description": "Tablet landscape and up." },
        "large":    { "$value": "1200px", "$type": "breakpoint", "$description": "Desktop." },
        "x-large":  { "$value": "1600px", "$type": "breakpoint", "$description": "Large desktop." }
    },
    "container": {
        "sm":    { "$value": "640px",  "$type": "dimension", "$description": "Page-width constraint, small. Unlike breakpoints these scale with the root font size, since a width cap should grow when the reader enlarges text (Constitution Art.1)." },
        "md":    { "$value": "768px",  "$type": "dimension", "$description": "Page-width constraint, medium." },
        "lg":    { "$value": "1024px", "$type": "dimension", "$description": "Page-width constraint, large." },
        "xl":    { "$value": "1280px", "$type": "dimension", "$description": "Page-width constraint, extra large." },
        "prose": { "$value": "66ch",   "$type": "dimension", "$description": "Measure. Body text stops at ~66ch however wide its container is — the single explicit exception to fill-by-default, because readability outranks full width (layout.md §2)." }
    }
}
