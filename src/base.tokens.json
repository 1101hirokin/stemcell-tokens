    "focus-ring": {
        "width": { "$type": "dimension", "$value": "2px", "$description": "Focus ring thickness (outline-width). WCAG 2.2 minimum." },
        "offset": { "$type": "dimension", "$value": "2px", "$description": "Focus ring offset (outline-offset). Gap between the element edge and the ring so the background shows through, improving visibility." },
        "style": { "$type": "strokeStyle", "$value": "solid", "$description": "Focus ring line style (outline-style)." }
    },
    "motion": {
        "duration": {
            "fast-01":     { "$value": "70ms",  "$type": "duration", "$description": "Carbon fast-01. Micro feedback." },
            "fast-02":     { "$value": "110ms", "$type": "duration", "$description": "Carbon fast-02. Hover/press/toggle feedback." },
            "moderate-01": { "$value": "150ms", "$type": "duration", "$description": "Carbon moderate-01. General transitions and exits." },
            "moderate-02": { "$value": "240ms", "$type": "duration", "$description": "Carbon moderate-02. Entrances and expand/collapse." },
            "slow-01":     { "$value": "400ms", "$type": "duration", "$description": "Carbon slow-01. Large surfaces." },
            "slow-02":     { "$value": "700ms", "$type": "duration", "$description": "Carbon slow-02. Loops (spinner/skeleton)." }
        },
        "easing": {
            "standard": { "$value": [0.2, 0.0, 0.38, 0.9], "$type": "cubicBezier", "$description": "ease-out. Entrances and general transitions; the spring fallback." },
            "exit":     { "$value": [0.2, 0.0, 1.0, 1.0],  "$type": "cubicBezier", "$description": "accelerate. Dismissals." },
            "linear":   { "$value": [0.0, 0.0, 1.0, 1.0],  "$type": "cubicBezier", "$description": "Linear. Loops and the none/reduced result." }
        },
        "scale": { "$value": 1, "$type": "number", "$description": "Ambient motion multiplier. Components multiply durations by this; reduced-motion sets it to 0 (Constitution Art.6)." },

        "none": {
            "duration": { "$value": "0ms", "$type": "duration", "$description": "Instant. The reduced-motion result." },
            "easing":   { "$value": "{motion.easing.linear}", "$type": "cubicBezier" }
        },
        "feedback": {
            "duration": { "$value": "{motion.duration.fast-02}", "$type": "duration", "$description": "Hover/press/toggle." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "transition": {
            "duration": { "$value": "{motion.duration.moderate-01}", "$type": "duration", "$description": "General property change." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "entrance": {
            "duration": { "$value": "{motion.duration.moderate-02}", "$type": "duration", "$description": "Element appears." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "exit": {
            "duration": { "$value": "{motion.duration.moderate-01}", "$type": "duration", "$description": "Element dismisses (faster than entrance)." },
            "easing":   { "$value": "{motion.easing.exit}", "$type": "cubicBezier" }
        },
        "expand": {
            "duration": { "$value": "{motion.duration.moderate-02}", "$type": "duration", "$description": "Accordion/collapse/disclosure height." },
            "easing":   { "$value": "{motion.easing.standard}", "$type": "cubicBezier" }
        },
        "loop": {
            "duration": { "$value": "{motion.duration.slow-02}", "$type": "duration", "$description": "Spinner/skeleton (infinite)." },
            "easing":   { "$value": "{motion.easing.linear}", "$type": "cubicBezier" }
        }
    },
    "layer": {
        "base":         { "$value": 0,    "$type": "number", "$description": "App ground plane: body / background / flat controls. Surface content (card, panel, alert, table) shares this z. Components must reference these tokens instead of writing raw z-index values (Constitution Art.3, structural layer)." },
        "navigation":   { "$value": 10,   "$type": "number", "$description": "Persistent chrome: app bar / sidebar / sticky header / tab bar." },
        "popover":      { "$value": 1000, "$type": "number", "$description": "Trigger-anchored transient surfaces: menu / dropdown / select / combobox / popover." },
        "scrim":        { "$value": 1300, "$type": "number", "$description": "Dimming veil behind a modal; sits below the modal it belongs to. Stacking order only — the visual value (color/opacity) belongs to elevation." },
        "modal":        { "$value": 1400, "$type": "number", "$description": "Focus-trapped surfaces: modal / dialog / drawer / sheet." },
        "notification": { "$value": 1700, "$type": "number", "$description": "Frontmost transient messages: toast / snackbar." },
        "tooltip":      { "$value": 1800, "$type": "number", "$description": "Above every other layer despite drawing at popover depth — visual depth and stacking order are separate axes." }
    }
}
