{
    "$extensions": {
        "stemcell": {
            "scheme": "light"
        }
    },
    "color": {
        "app": {
            "system": {
                "$value": "#007AFF",
                "$type": "color",
                "$description": "General-purpose system accent color. Defaults to a neutral blue; override in each theme to match platform conventions."
            },
            "background": {
                "$value": "#FFFFFF",
                "$type": "color"
            },
            "foreground": {
                "$value": "{color.gray.900}",
                "$type": "color"
            },
            "surface":        { "$value": "{color.app.background}", "$type": "color", "$description": "Raised surface (card/panel). Light: white; depth comes from shadow." },
            "surface-raised": { "$value": "{color.app.background}", "$type": "color", "$description": "Nested raised surface." },
            "overlay":        { "$value": "{color.app.background}", "$type": "color", "$description": "Popover/modal surface." },
            "fg-muted":       { "$value": "{color.gray.600}", "$type": "color", "$description": "Secondary text." },
            "fg-subtle":      { "$value": "{color.gray.500}", "$type": "color", "$description": "Supplementary text." },
            "fg-disabled":    { "$value": "{color.gray.400}", "$type": "color", "$description": "Disabled text." },
            "link":           { "$value": "{color.app.system}", "$type": "color", "$description": "Hyperlink text." },
            "border":         { "$value": "{color.gray.200}", "$type": "color", "$description": "Neutral border." },
            "divider":        { "$value": "{color.gray.100}", "$type": "color", "$description": "Neutral divider." },
            "shadow":         { "$value": "{color.gray.900}", "$type": "color", "$description": "Elevation shadow color (slightly-blue near-black)." },
            "scrim":          { "$value": "{color.gray.900}", "$type": "color", "$description": "Modal scrim color (used at ~0.5 opacity)." }
        },
        "brand": {
            "50": { "$value": "#ebe9fb", "$type": "color" },
            "100": { "$value": "#c1b9f2", "$type": "color" },
            "200": { "$value": "#a398ec", "$type": "color" },
            "300": { "$value": "#7868e4", "$type": "color" },
            "400": { "$value": "#5e4bde", "$type": "color" },
            "500": { "$value": "#361ed6", "$type": "color" },
            "600": { "$value": "#311bc3", "$type": "color" },
            "700": { "$value": "#261598", "$type": "color" },
            "800": { "$value": "#1e1176", "$type": "color" },
            "900": { "$value": "#170d5a", "$type": "color" }
        },
        "semantic": {
            "focus-ring": {
                "$value": "{color.app.system}",
                "$type": "color",
                "$description": "Global focus ring color. Defaults to app.system; override per theme."
            },
            "primary": {
                "bg": { "$value": "{color.brand.600}", "$type": "color" },
                "fg": { "$value": "#ffffff", "$type": "color" },
                "border": {
                    "$value": "{color.semantic.primary.bg}",
                    "$type": "color"
                },
                "icon": {
                    "$value": "{color.semantic.primary.fg}",
                    "$type": "color"
                },
                "focus-ring": {
                    "$value": "{color.semantic.focus-ring}",
                    "$type": "color"
                },
                "bg-hover": {
                    "$value": "{color.brand.700}",
                    "$type": "color"
                },
                "bg-pressed": {
                    "$value": "{color.brand.800}",
                    "$type": "color"
                },
                "soft-bg": { "$value": "{color.brand.50}", "$type": "color" },
                "soft-fg": { "$value": "{color.brand.800}", "$type": "color" },
                "soft-border": {
                    "$value": "{color.brand.300}",
                    "$type": "color"
                },
                "soft-bg-hover": {
                    "$value": "{color.brand.100}",
                    "$type": "color"
                },
                "soft-bg-pressed": {
                    "$value": "{color.brand.200}",
                    "$type": "color"
                }
            },
            "danger": {
                "bg": { "$value": "{color.red.600}", "$type": "color" },
                "fg": { "$value": "#ffffff", "$type": "color" },
                "border": {
                    "$value": "{color.semantic.danger.bg}",
                    "$type": "color"
                },
                "icon": {
                    "$value": "{color.semantic.danger.fg}",
                    "$type": "color"
                },
                "focus-ring": {
                    "$value": "{color.semantic.focus-ring}",
                    "$type": "color"
                },
                "bg-hover": {
                    "$value": "{color.red.700}",
                    "$type": "color"
                },
                "bg-pressed": {
                    "$value": "{color.red.800}",
                    "$type": "color"
                },
                "soft-bg": { "$value": "{color.red.50}", "$type": "color" },
                "soft-fg": {
                    "$value": "{color.red.800}",
                    "$type": "color"
                },
                "soft-border": {
                    "$value": "{color.red.300}",
                    "$type": "color"
                },
                "soft-bg-hover": {
                    "$value": "{color.red.100}",
                    "$type": "color"
                },
                "soft-bg-pressed": {
                    "$value": "{color.red.200}",
                    "$type": "color"
                }
            },
            "warning": {
                "bg": { "$value": "{color.yellow.600}", "$type": "color" },
                "fg": { "$value": "#ffffff", "$type": "color" },
                "border": {
                    "$value": "{color.semantic.warning.bg}",
                    "$type": "color"
                },
                "icon": {
                    "$value": "{color.semantic.warning.fg}",
                    "$type": "color"
                },
                "focus-ring": {
                    "$value": "{color.semantic.focus-ring}",
                    "$type": "color"
                },
                "bg-hover": {
                    "$value": "{color.yellow.700}",
                    "$type": "color"
                },
                "bg-pressed": {
                    "$value": "{color.yellow.800}",
                    "$type": "color"
                },
                "soft-bg": {
                    "$value": "{color.yellow.50}",
                    "$type": "color"
                },
                "soft-fg": {
                    "$value": "{color.yellow.800}",
                    "$type": "color"
                },
                "soft-border": {
                    "$value": "{color.yellow.300}",
                    "$type": "color"
                },
                "soft-bg-hover": {
                    "$value": "{color.yellow.100}",
                    "$type": "color"
                },
                "soft-bg-pressed": {
                    "$value": "{color.yellow.200}",
                    "$type": "color"
                }
            },
            "success": {
                "bg": { "$value": "{color.green.600}", "$type": "color" },
                "fg": { "$value": "#ffffff", "$type": "color" },
                "border": {
                    "$value": "{color.semantic.success.bg}",
                    "$type": "color"
                },
                "icon": {
                    "$value": "{color.semantic.success.fg}",
                    "$type": "color"
                },
                "focus-ring": {
                    "$value": "{color.semantic.focus-ring}",
                    "$type": "color"
                },
                "bg-hover": {
                    "$value": "{color.green.700}",
                    "$type": "color"
                },
                "bg-pressed": {
                    "$value": "{color.green.800}",
                    "$type": "color"
                },
                "soft-bg": {
                    "$value": "{color.green.50}",
                    "$type": "color"
                },
                "soft-fg": {
                    "$value": "{color.green.800}",
                    "$type": "color"
                },
                "soft-border": {
                    "$value": "{color.green.300}",
                    "$type": "color"
                },
                "soft-bg-hover": {
                    "$value": "{color.green.100}",
                    "$type": "color"
                },
                "soft-bg-pressed": {
                    "$value": "{color.green.200}",
                    "$type": "color"
                }
            },
            "info": {
                "bg":              { "$value": "{color.blue.600}", "$type": "color" },
                "fg":              { "$value": "#ffffff",          "$type": "color" },
                "border":          { "$value": "{color.semantic.info.bg}", "$type": "color" },
                "icon":            { "$value": "{color.semantic.info.fg}", "$type": "color" },
                "focus-ring":      { "$value": "{color.semantic.focus-ring}", "$type": "color" },
                "bg-hover":        { "$value": "{color.blue.700}", "$type": "color" },
                "bg-pressed":      { "$value": "{color.blue.800}", "$type": "color" },
                "soft-bg":         { "$value": "{color.blue.50}",  "$type": "color" },
                "soft-fg":         { "$value": "{color.blue.800}", "$type": "color" },
                "soft-border":     { "$value": "{color.blue.300}", "$type": "color" },
                "soft-bg-hover":   { "$value": "{color.blue.100}", "$type": "color" },
                "soft-bg-pressed": { "$value": "{color.blue.200}", "$type": "color" }
            },
            "plain": {
                "bg": { "$value": "{color.gray.600}", "$type": "color" },
                "fg": { "$value": "#ffffff", "$type": "color" },
                "border": {
                    "$value": "{color.semantic.plain.bg}",
                    "$type": "color"
                },
                "icon": {
                    "$value": "{color.semantic.plain.fg}",
                    "$type": "color"
                },
                "focus-ring": {
                    "$value": "{color.semantic.focus-ring}",
                    "$type": "color"
                },
                "bg-hover": {
                    "$value": "{color.gray.700}",
                    "$type": "color"
                },
                "bg-pressed": {
                    "$value": "{color.gray.800}",
                    "$type": "color"
                },
                "soft-bg": {
                    "$value": "{color.gray.50}",
                    "$type": "color"
                },
                "soft-fg": {
                    "$value": "{color.gray.800}",
                    "$type": "color"
                },
                "soft-border": {
                    "$value": "{color.gray.300}",
                    "$type": "color"
                },
                "soft-bg-hover": {
                    "$value": "{color.gray.100}",
                    "$type": "color"
                },
                "soft-bg-pressed": {
                    "$value": "{color.gray.200}",
                    "$type": "color"
                }
            },
            "disabled": {
                "bg": { "$value": "{color.gray.200}", "$type": "color" },
                "fg": { "$value": "{color.gray.400}", "$type": "color" },
                "border": {
                    "$value": "{color.semantic.disabled.bg}",
                    "$type": "color"
                },
                "icon": {
                    "$value": "{color.semantic.disabled.fg}",
                    "$type": "color"
                },
                "soft-bg": {
                    "$value": "{color.gray.100}",
                    "$type": "color"
                },
                "soft-fg": {
                    "$value": "{color.gray.300}",
                    "$type": "color"
                },
                "soft-border": {
                    "$value": "{color.gray.200}",
                    "$type": "color"
                }
            }
        }
    },

    "elevation": {
        "flat": {
            "surface": { "$value": "{color.app.background}", "$type": "color", "$description": "Ground plane. Light keeps every level untinted, so the whole surface facet resolves to background here; the tonal ladder only opens up in dark (elevation.md §5)." },
            "shadow":  { "$value": [], "$type": "shadow", "$description": "Flat sits on the ground plane and casts nothing." }
        },
        "surface": {
            "surface": { "$value": "{color.app.surface}", "$type": "color" },
            "shadow":  { "$value": [
                { "color": "{color.app.shadow}", "alpha": 0.24, "offsetX": "0px", "offsetY": "1px", "blur": "1px" },
                { "color": "{color.app.shadow}", "alpha": 0.14, "offsetX": "0px", "offsetY": "1px", "blur": "2px" }
            ], "$type": "shadow", "$description": "Card / panel / alert / table. umbra (tight, dark) over penumbra (wide, soft), lit from directly above. The two-layer geometry is this platform's expression of the level, not the level itself — a platform that can only draw one shadow keeps the level and renders one (Constitution Art.7)." }
        },
        "navigation": {
            "surface": { "$value": "{color.app.surface}", "$type": "color" },
            "shadow":  { "$value": [
                { "color": "{color.app.shadow}", "alpha": 0.24, "offsetX": "0px", "offsetY": "1px", "blur": "2px" },
                { "color": "{color.app.shadow}", "alpha": 0.14, "offsetX": "0px", "offsetY": "2px", "blur": "4px" }
            ], "$type": "shadow", "$description": "App bar / sidebar / sticky header / tab bar." }
        },
        "popover": {
            "surface": { "$value": "{color.app.surface-raised}", "$type": "color" },
            "shadow":  { "$value": [
                { "color": "{color.app.shadow}", "alpha": 0.24, "offsetX": "0px", "offsetY": "2px", "blur": "3px" },
                { "color": "{color.app.shadow}", "alpha": 0.14, "offsetX": "0px", "offsetY": "4px", "blur": "8px" }
            ], "$type": "shadow", "$description": "Menu / dropdown / select / combobox / popover. Tooltip draws at this depth but stacks at --layer-tooltip." }
        },
        "modal": {
            "surface": { "$value": "{color.app.overlay}", "$type": "color" },
            "shadow":  { "$value": [
                { "color": "{color.app.shadow}", "alpha": 0.24, "offsetX": "0px", "offsetY": "3px", "blur": "5px" },
                { "color": "{color.app.shadow}", "alpha": 0.14, "offsetX": "0px", "offsetY": "8px", "blur": "16px" }
            ], "$type": "shadow", "$description": "Modal / dialog / drawer / sheet." }
        },
        "notification": {
            "surface": { "$value": "{color.app.overlay}", "$type": "color" },
            "shadow":  { "$value": [
                { "color": "{color.app.shadow}", "alpha": 0.24, "offsetX": "0px", "offsetY": "4px", "blur": "6px" },
                { "color": "{color.app.shadow}", "alpha": 0.14, "offsetX": "0px", "offsetY": "12px", "blur": "24px" }
            ], "$type": "shadow", "$description": "Toast / snackbar." }
        }
    },

    "scrim": {
        "$value": "{color.app.scrim}",
        "$type": "color",
        "$extensions": { "stemcell": { "alpha": 0.5 } },
        "$description": "Veil behind modal / dialog / drawer. Stacking order is --layer-scrim; this token carries the visual value only (elevation.md §6)."
    }
}
